# DivineConnect Environment Variables
# Copy this file to .env and fill in your values

# Firebase Configuration
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (server-side only)
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio SMS Gateway (OTP fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid Email (transactional emails)
SENDGRID_API_KEY=

# Google OAuth (Google Sign-In)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Expo / React Native
EXPO_PUBLIC_API_URL=https://us-central1-<your-project>.cloudfunctions.net
EXPO_PUBLIC_RAZORPAY_KEY=

# Admin Dashboard
VITE_API_URL=https://us-central1-<your-project>.cloudfunctions.net
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Deployment
SITE_URL=https://divyaasirwad.com
GA_MEASUREMENT_ID=G-XXXXXXXXXX
