{
  "name": "divyaasirwad",
  "projectId": "divyaasirwad",
  "storageBucket": "divyaasirwad.appspot.com",
  "location": "us-central1",
  "functions": {
    "source": "packages/api",
    "runtime": "nodejs18",
    "ignore": ["node_modules", ".git", "*.log"],
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "firestore": {
    "rules": "infra/firebase/firestore.rules",
    "indexes": "infra/firebase/firestore.indexes.json"
  },
  "hosting": {
    "public": "packages/admin/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  },
  "storage": {
    "rules": "infra/firebase/storage.rules"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
